# Root .env.example — copy relevant vars into server/.env and client/.env

# ---- SERVER ----
MONGO_URI=mongodb://localhost:27017/brewbuddy
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d
PORT=5001
NODE_ENV=development

# ---- GOOGLE APIs ----
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# ---- CLIENT ----
VITE_API_URL=http://localhost:5001/api
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_js_api_key_here
